<?xml version="1.0" encoding="UTF-8"?>
<!--
    Pre-patched pom for edu.gmu.swe.greensolver:green:1.0-SNAPSHOT.
    Applied by .github/scripts/bootstrap-local-deps.sh.

    The upstream pom at gmu-swe/green-solver is bare (no source-dir, no
    deps, no excludes) and does not build on modern JDKs out of the box.
    Changes from upstream:
      * <sourceDirectory>src</sourceDirectory> — repo uses Ant layout.
      * <source>/<target>8 — upstream's 7 is no longer supported by modern javac.
      * <excludes> — choco/choco3 bindings reference different versions of
        choco-solver and the smtlib2 parser references a nonexistent
        NullLogger class; all three subtrees are excluded.
      * <dependencies> — declare local-m2 stand-ins for the jars bundled
        in green-solver/green/lib/ that the pom forgets to wire up.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>

    <groupId>edu.gmu.swe.greensolver</groupId>
    <artifactId>green</artifactId>
    <version>1.0-SNAPSHOT</version>

    <dependencies>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>microsoft-z3</artifactId>
            <version>4.8.9</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>apfloat</artifactId>
            <version>1.0</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>choco-solver</artifactId>
            <version>2.1.3</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>trove</artifactId>
            <version>3.1a1</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>libcvc3</artifactId>
            <version>1.0</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>jedis</artifactId>
            <version>2.0</version>
        </dependency>
        <dependency>
            <groupId>green-local</groupId>
            <artifactId>commons-exec</artifactId>
            <version>1.2</version>
        </dependency>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>1.7.12</version>
        </dependency>
    </dependencies>

    <build>
        <sourceDirectory>src</sourceDirectory>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>8</source>
                    <target>8</target>
                    <excludes>
                        <exclude>**/choco/*.java</exclude>
                        <exclude>**/choco3/*.java</exclude>
                        <exclude>**/parser/**/*.java</exclude>
                    </excludes>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
